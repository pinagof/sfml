{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Compilar",
      "type": "shell",
      "command": "cmake --build build --parallel",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$gcc"
    },
    {
      "label": "CMake: Configurar",
      "type": "shell",
      "command": "cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Debug",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake: Compilar y Ejecutar",
      "type": "shell",
      "command": "cmake --build build --parallel && Xvfb :99 -screen 0 1280x720x24 & sleep 1 && DISPLAY=:99 ./build/MiProyectoSFML",
      "group": "test",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Limpiar build",
      "type": "shell",
      "command": "rm -rf build",
      "group": "build",
      "problemMatcher": []
    }
  ]
}