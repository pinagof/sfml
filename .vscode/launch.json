{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug: MiProyectoSFML",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/MiProyectoSFML",
      "cwd": "${workspaceFolder}",
      "environment": [{ "name": "DISPLAY", "value": ":99" }],
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: Compilar",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "ignoreFailures": true }
      ]
    }
  ]
}